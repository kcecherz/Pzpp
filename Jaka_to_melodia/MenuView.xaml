<UserControl x:Class="Jaka_to_melodia.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Jaka_to_melodia"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="LightBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="JAKA TO MELODIA?" FontSize="32" FontWeight="Bold" 
               HorizontalAlignment="Center" Margin="20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <TextBlock Text="Podaj nick:" VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0"/>
            <TextBox x:Name="TxtPlayerName" Width="150" Height="30" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button x:Name="BtnAddProfile" Content="Dodaj Profil" Width="100" Height="30" Click="BtnAddProfile_Click"/>
        </StackPanel>

        <ListBox x:Name="ListProfiles" Grid.Row="2" Margin="50,10,50,10" FontSize="18" 
             DisplayMemberPath="Name" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">

            <Button x:Name="BtnDeleteProfile" Content="Usuń profil" Width="120" Height="50" 
                FontSize="16" Background="#FF7F7F" Margin="0,0,20,0" Click="BtnDeleteProfile_Click"/>

            <Button x:Name="BtnStart" Content="START GRY" Width="200" Height="50" 
                FontSize="20" FontWeight="Bold" Click="BtnStart_Click" />

        </StackPanel>
    </Grid>
</UserControl>
