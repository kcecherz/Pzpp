<UserControl x:Class="Jaka_to_melodia.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Jaka_to_melodia"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="LightBlue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtPlayerName" Grid.Row="0" FontSize="18" FontWeight="Bold" Foreground="DarkBlue"
               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10"/>

        <TextBlock Grid.Row="1" Text="Słuchaj uważnie..." FontSize="36" FontWeight="Bold" Foreground="#333"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <UniformGrid Grid.Row="2" Rows="2" Columns="2" Margin="20" Height="200">
            <Button x:Name="BtnAnswer1" Content="Odpowiedź 1" FontSize="20" Margin="10" Click="BtnAnswer_Click" Background="#FFF"/>
            <Button x:Name="BtnAnswer2" Content="Odpowiedź 2" FontSize="20" Margin="10" Click="BtnAnswer_Click" Background="#FFF"/>
            <Button x:Name="BtnAnswer3" Content="Odpowiedź 3" FontSize="20" Margin="10" Click="BtnAnswer_Click" Background="#FFF"/>
            <Button x:Name="BtnAnswer4" Content="Odpowiedź 4" FontSize="20" Margin="10" Click="BtnAnswer_Click" Background="#FFF"/>
        </UniformGrid>

        <Button x:Name="BtnBack" Grid.Row="3" Content="Zakończ grę" Width="150" Height="40" 
            HorizontalAlignment="Center" Margin="0,10,0,20" Click="BtnBack_Click" Background="#FF7F7F"/>
    </Grid>
</UserControl>